# Gemini API Key (from https://aistudio.google.com/)
GOOGLE_API_KEY=your-gemini-api-key-here

# Agent server config
HOST=0.0.0.0
PORT=8001

# API key for securing the agent endpoint
HOMEWARD_API_KEY=your-agent-api-key-here

# FHIR server base URL (provided by Prompt Opinion via SHARP context)
# FHIR_BASE_URL=https://fhir.example.com
# FHIR_TOKEN= (passed at runtime via SHARP-on-MCP)

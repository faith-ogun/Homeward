# ── Required ───────────────────────────────────────────────────────────────────

# Google API key — used by google-adk to call Gemini
# Get yours at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here

# ── Model provider ─────────────────────────────────────────────────────────────

# Set to FALSE to use your AI Studio API key (free Gemini quota).
# Keeping this FALSE avoids Vertex AI billing entirely.
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# ── Agent security ─────────────────────────────────────────────────────────────

# API key that callers (Prompt Opinion) must send in the X-API-Key header.
# If not set, falls back to 'homeward-dev-key-123' for local testing.
# HOMEWARD_API_KEY=your-agent-api-key-here

# ── Agent public URL ───────────────────────────────────────────────────────────

# Set after deploying so the agent card advertises the correct URL.
# Leave as default when running locally.
# HOMEWARD_URL=https://homeward-abc123-uc.a.run.app

# If using ngrok, set BASE_URL to have the agent use it.
# BASE_URL=https://my-agent.ngrok-free.app

# ── Prompt Opinion ─────────────────────────────────────────────────────────────

# The base URL of your Prompt Opinion workspace (for FHIR extension URI).
# PO_PLATFORM_BASE_URL=https://app.promptopinion.ai

# ── Logging ────────────────────────────────────────────────────────────────────

# Log the full JSON-RPC request body on every incoming request (default: true)
# LOG_FULL_PAYLOAD=true

# Dump raw ADK callback objects before every LLM call (default: false)
# LOG_HOOK_RAW_OBJECTS=false
